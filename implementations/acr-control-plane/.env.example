# ACR Control Plane — Environment Variable Template
#
# HOW TO USE:
#   Development : cp .env.example .env  (defaults work for local docker-compose)
#   Staging/Prod: populate each CHANGE_ME value with a strong random secret.
#                 Use a secrets manager (Vault, AWS SM, K8s Secrets) — never
#                 commit real credentials to version control.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://acr:acr_dev_password@localhost:5432/acr_control_plane

# Postgres service credentials (used by docker-compose postgres healthcheck)
POSTGRES_USER=acr
POSTGRES_PASSWORD=acr_dev_password
POSTGRES_DB=acr_control_plane

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Open Policy Agent ─────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181

# ── Kill Switch ───────────────────────────────────────────────────────────────
KILLSWITCH_URL=http://localhost:8443
# Minimum 32 random bytes (hex). Required on ALL kill switch endpoints.
# Dev default is rejected in staging/production at startup.
KILLSWITCH_SECRET=killswitch_dev_secret_change_me

# ── JWT Authentication ────────────────────────────────────────────────────────
# HS256 requires >= 256-bit (32-byte) key.
# The server will refuse to start in non-development environments if this
# is set to a known-weak value or fewer than 32 bytes.
JWT_SECRET_KEY=dev_jwt_secret_change_in_production
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRE_MINUTES=30

# ── Runtime ───────────────────────────────────────────────────────────────────
# Accepted values: development | staging | production
# Non-development environments enforce strong secret validation at startup.
ACR_ENV=development
LOG_LEVEL=INFO
ACR_VERSION=1.0
SCHEMA_BOOTSTRAP_MODE=auto
STRICT_DEPENDENCY_STARTUP=false

# ── Operator Auth / RBAC ─────────────────────────────────────────────────────
# JSON object keyed by API key. Each value must include a subject and roles.
# Example:
# OPERATOR_API_KEYS_JSON={"change-me":{"subject":"platform-admin","roles":["agent_admin","approver","security_admin","auditor","killswitch_operator"]}}
OPERATOR_API_KEYS_JSON=
# Used by the main gateway when it calls the independent kill switch service.
SERVICE_OPERATOR_API_KEY=
OPERATOR_SESSION_SECRET=dev_operator_session_secret_change_me
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
OIDC_JWKS_URL=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email groups
OIDC_ROLES_CLAIM=groups
OIDC_SUBJECT_CLAIM=email
OIDC_ROLE_MAPPING_JSON=
OIDC_SESSION_TTL_SECONDS=28800

# ── Approval Webhook ─────────────────────────────────────────────────────────
# Leave blank to disable outbound webhook notifications.
WEBHOOK_URL=
# If set, each webhook POST carries X-ACR-Signature: <hmac-sha256-hex>.
# Receivers must verify this header before trusting the payload.
# Minimum 32 random bytes (hex). Leave blank to skip signing.
WEBHOOK_HMAC_SECRET=
# Minimum 32 random bytes (hex). Used to sign audit/evidence bundles.
AUDIT_SIGNING_SECRET=dev_audit_signing_secret_change_me

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Leave blank to disable OTLP trace export (e.g. http://localhost:4318).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=acr-control-plane

# ── Downstream Execution ─────────────────────────────────────────────────────
# If true, allowed actions and approved escalations will POST to the configured tool executor URL.
EXECUTE_ALLOWED_ACTIONS=false
# Example: {"query_customer_db":"https://executor.internal/query-customer","issue_refund":"https://executor.internal/refund"}
TOOL_EXECUTOR_MAP_JSON=
# Structured integrations for common live business actions.
# Supported providers: refund_api, email_api, ticket_api, http
# Secret values can be referenced with env:NAME
EXECUTOR_INTEGRATIONS_JSON=
# Optional HMAC secret used to sign execution payloads with X-ACR-Execution-Signature.
EXECUTOR_HMAC_SECRET=
# Short-lived execution authorization TTL. Downstream executors should verify
# X-ACR-Execution-Token so actions cannot bypass the control plane.
EXECUTOR_AUTH_TTL_SECONDS=60
# Optional secret used to mint short-lived brokered downstream credentials.
# Downstream services can verify X-ACR-Brokered-Credential for audience/scope.
EXECUTOR_CREDENTIAL_SECRET=
EXECUTOR_CREDENTIAL_TTL_SECONDS=300
EXECUTOR_TIMEOUT_SECONDS=8.0

# ── Policy Bundle Publishing ────────────────────────────────────────────────
# Supported backends:
#   local : write bundles to the local filesystem
#   s3    : write bundles to S3 or an S3-compatible object store
REQUIRE_BUNDLE_AUTH=true
POLICY_BUNDLE_BACKEND=local
POLICY_BUNDLE_LOCAL_DIR=./var/policy_bundles
# Required when POLICY_BUNDLE_BACKEND=s3
POLICY_BUNDLE_S3_BUCKET=
# Optional key prefix inside the bucket
POLICY_BUNDLE_S3_PREFIX=acr/policy-bundles
# Optional AWS region / S3-compatible region hint
POLICY_BUNDLE_S3_REGION=
# Optional S3-compatible endpoint URL (e.g. MinIO, R2, Ceph)
POLICY_BUNDLE_S3_ENDPOINT_URL=
# Optional public/base URL shown in release history instead of a filesystem path.
POLICY_BUNDLE_PUBLIC_BASE_URL=
