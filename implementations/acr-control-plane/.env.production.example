# ACR Control Plane — Production Environment Template
#
# Populate these values from a secret manager or generated output from:
#   python scripts/generate_secrets.py > .env.production
#
# Do not commit real production values.

DATABASE_URL=postgresql+asyncpg://acr:${POSTGRES_PASSWORD}@db.example.internal:5432/acr_control_plane
REDIS_URL=redis://redis.example.internal:6379/0
OPA_URL=http://opa.example.internal:8181
KILLSWITCH_URL=http://acr-killswitch.example.internal:8443

POSTGRES_USER=acr
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=acr_control_plane

JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRE_MINUTES=30

KILLSWITCH_SECRET=CHANGE_ME
AUDIT_SIGNING_SECRET=CHANGE_ME
OPERATOR_SESSION_SECRET=CHANGE_ME
WEBHOOK_HMAC_SECRET=CHANGE_ME
EXECUTOR_HMAC_SECRET=CHANGE_ME
EXECUTOR_CREDENTIAL_SECRET=CHANGE_ME
EXECUTOR_AUTH_TTL_SECONDS=60
EXECUTOR_CREDENTIAL_TTL_SECONDS=300

ACR_ENV=production
LOG_LEVEL=INFO
SCHEMA_BOOTSTRAP_MODE=validate
STRICT_DEPENDENCY_STARTUP=true

OPERATOR_API_KEYS_JSON=CHANGE_ME
SERVICE_OPERATOR_API_KEY=CHANGE_ME

OIDC_ENABLED=true
OIDC_ISSUER=https://idp.example.com
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_AUTHORIZE_URL=https://idp.example.com/oauth2/authorize
OIDC_TOKEN_URL=https://idp.example.com/oauth2/token
OIDC_JWKS_URL=https://idp.example.com/.well-known/jwks.json
OIDC_REDIRECT_URI=https://acr.example.com/acr/auth/oidc/callback
OIDC_SCOPES=openid profile email groups
OIDC_ROLES_CLAIM=groups
OIDC_SUBJECT_CLAIM=email
OIDC_ROLE_MAPPING_JSON={"acr-platform-admin":["agent_admin","approver","security_admin","auditor","killswitch_operator"]}

EXECUTE_ALLOWED_ACTIONS=true
TOOL_EXECUTOR_MAP_JSON=CHANGE_ME
EXECUTOR_INTEGRATIONS_JSON=

WEBHOOK_URL=
OTEL_EXPORTER_OTLP_ENDPOINT=

POLICY_BUNDLE_BACKEND=s3
POLICY_BUNDLE_S3_BUCKET=CHANGE_ME
POLICY_BUNDLE_S3_PREFIX=acr/policy-bundles
POLICY_BUNDLE_S3_REGION=us-east-1
POLICY_BUNDLE_S3_ENDPOINT_URL=
POLICY_BUNDLE_PUBLIC_BASE_URL=
